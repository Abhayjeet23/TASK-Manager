# ── Server ──────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ──────────────────────────────
# Local:   mongodb://localhost:27017/mern_taskmanager
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/mern_taskmanager
MONGO_URI=mongodb://localhost:27017/mern_taskmanager

# ── JWT ──────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────
CLIENT_URL=http://:3000
